# Work project folders
[includeIf "gitdir:~/Projects/"]
    path = ~/.gitconfig-work

# Personal project folders
[includeIf "gitdir:~/Code/"]
    path = ~/.gitconfig-personal

[includeIf "gitdir:~/dotfiles/"]
    path = ~/.gitconfig-personal

# Machine-level override — loaded last so it wins over all conditional includes above.
# On a personal machine, set user/email/signingkey here and skip work-local/personal-local entirely.
[include]
    path = ~/.gitconfig-local

# Global Git settings
[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = base16

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = false

[init]
    defaultBranch = main
