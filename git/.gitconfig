# Include local user configuration (not tracked in git)
[include]
    path = ~/.gitconfig-local

# Work project folders
[includeIf "gitdir:~/Projects/"]
    path = ~/.gitconfig-work

# Personal project folders
[includeIf "gitdir:~/Code/"]
    path = ~/.gitconfig-personal

[includeIf "gitdir:~/dotfiles/"]
    path = ~/.gitconfig-personal

# Global Git settings
[core]
    excludesfile = ~/.gitignore_global
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = base16

[push]
    default = simple
    autoSetupRemote = true

[pull]
    rebase = false

[init]
    defaultBranch = main
